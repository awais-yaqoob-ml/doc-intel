# ==========================================
# Application
# ==========================================
APP_NAME=doc-intel
APP_ENV=local
DEBUG=true
LOG_LEVEL=INFO

# ==========================================
# API
# ==========================================
API_HOST=0.0.0.0
API_PORT=8000

# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=docintel
POSTGRES_USER=docintel
POSTGRES_PASSWORD=docintel

# ==========================================
# Qdrant
# ==========================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=document_chunks

# ==========================================
# Raw Storage
# ==========================================
RAW_STORAGE_PATH=./data/raw

# ==========================================
# Embeddings
# ==========================================
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=32

# ==========================================
# OCR
# ==========================================
OCR_ENGINE=rapidocr
OCR_MAX_CONCURRENCY=2

# ==========================================
# Parsing
# ==========================================
PARSER_MAX_CONCURRENCY=4

# ==========================================
# Enrichment
# ==========================================
NER_MODEL=urchade/gliner_medium-v2.1

# ==========================================
# Groq
# ==========================================
GROQ_API_KEY=

GROQ_MODEL=llama-3.3-70b-versatile

GROQ_MAX_RETRIES=5
GROQ_TIMEOUT_SECONDS=120
GROQ_MAX_CONCURRENCY=3

# ==========================================
# Chunking
# ==========================================
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# ==========================================
# Pipeline
# ==========================================
MAX_DOCUMENT_CONCURRENCY=5

# ==========================================
# Google Drive
# ==========================================
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-service-account.json